---
import Base from '../../layouts/Base.astro';

const posts = [
  { tag: 'Capabilities', title: 'What the latest model releases actually mean for government deployment', excerpt: "Everyone covered what dropped. Nobody covered what it means when your users can't paste classified data into it.", date: 'Mar 2026', readTime: '8 min', slug: 'model-releases-government-deployment' },
  { tag: 'Enterprise', title: 'Building an AI briefing system without social media', excerpt: "The sources, the workflow, and the prompts I use to stay current when doom-scrolling isn't an option.", date: 'Feb 2026', readTime: '6 min', slug: 'ai-briefing-without-social-media' },
  { tag: 'Vendor', title: 'What vendor AI demos never show you — and what to ask', excerpt: 'Four questions that separate real capability from slide-ware, after sitting through hundreds of pitches.', date: 'Feb 2026', readTime: '10 min', slug: 'vendor-ai-demo-questions' },
  { tag: 'Capabilities', title: 'Reasoning models in government: what actually changes', excerpt: 'The benchmark numbers are impressive. The deployment constraints are the real story.', date: 'Jan 2026', readTime: '7 min', slug: 'reasoning-models-government' },
];
---

<Base title="Writing" description="Perspectives on deploying AI inside the DoD — capabilities, enterprise patterns, and vendor reality.">
  <div class="page-wrap">
    <header class="page-header">
      <p class="eyebrow">Writing</p>
      <h1 class="page-title">Dispatches from inside the machine</h1>
      <p class="page-sub">Perspectives on AI capabilities, enterprise deployment, and vendor reality — from someone actually doing it inside the DoD.</p>
    </header>

    <div class="post-list">
      {posts.map(post => (
        <a href={`/writing/${post.slug}`} class="post-row">
          <div class="post-row-meta">
            <span class="tag-pill">{post.tag}</span>
            <span class="post-date">{post.date}</span>
            <span class="post-time">{post.readTime} read</span>
          </div>
          <h2 class="post-row-title">{post.title}</h2>
          <p class="post-row-excerpt">{post.excerpt}</p>
        </a>
      ))}
    </div>
  </div>
</Base>

<style>
  .page-wrap { max-width: 800px; margin: 0 auto; padding: 120px 32px 80px; }
  .page-header { margin-bottom: 64px; }
  .eyebrow {
    font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--accent); margin-bottom: 12px;
  }
  .page-title { font-size: 40px; font-weight: 600; letter-spacing: -0.03em; color: var(--white); margin-bottom: 16px; }
  .page-sub { font-size: 16px; color: var(--text); line-height: 1.7; max-width: 560px; }

  .post-list { display: flex; flex-direction: column; gap: 0; }
  .post-row {
    padding: 32px 0; border-top: 1px solid var(--border);
    display: block; transition: all 0.15s;
  }
  .post-row:last-child { border-bottom: 1px solid var(--border); }
  .post-row:hover .post-row-title { color: var(--white); }
  .post-row-meta { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
  .post-date, .post-time {
    font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--muted);
  }
  .post-row-title { font-size: 20px; font-weight: 500; color: var(--primary); line-height: 1.3; margin-bottom: 10px; transition: color 0.15s; }
  .post-row-excerpt { font-size: 14px; color: var(--mid); line-height: 1.65; }
</style>
