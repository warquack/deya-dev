---
import Base from '../layouts/Base.astro';

const categories = [
  {
    name: 'Briefing & Summarization',
    prompts: [
      { title: 'Executive AI Brief', desc: 'Summarize AI news for senior leadership with strategic implications.', prompt: 'You are a senior technology advisor briefing DoD leadership. Summarize the following AI developments in plain language. For each item: (1) what happened, (2) why it matters for government/enterprise AI deployment, (3) any action required. Keep the total brief to one page. Prioritize implications over technical details.\n\n[Paste your content here]' },
      { title: 'Weekly Signal Digest', desc: 'Process a week of AI news into a structured personal digest.', prompt: "Analyze these AI news items from the past week. Organize them into: CAPABILITIES (what models can do now that they couldn't last week), ENTERPRISE (deployment, tooling, and workflow changes), VENDOR MOVES (strategic shifts in the commercial landscape), POLICY (government and regulatory developments). For each item, add a one-sentence 'so what' for someone deploying AI in a classified enterprise environment.\n\n[Paste news items here]" },
      { title: 'Research Paper TL;DR', desc: 'Extract practical implications from AI research papers.', prompt: 'Read this AI research paper and extract: (1) The core capability or finding in one sentence, (2) How this differs from previous work, (3) Practical deployment implications for enterprise government use cases, (4) Timeline to practical availability (research → product → FedRAMP authorization). Flag any national security or dual-use implications.\n\n[Paste paper abstract or full text]' },
    ],
  },
  {
    name: 'Vendor Evaluation',
    prompts: [
      { title: 'Vendor Deck Autopsy', desc: 'Deconstruct vendor pitch decks to find what they\'re hiding.', prompt: "You are a skeptical DoD program manager reviewing an AI vendor pitch deck. Identify: (1) Claims made without evidence, (2) Features shown in demo that likely require clean/synthetic data, (3) What the 'customer success stories' don't mention about deployment complexity, (4) Security and compliance claims that need verification, (5) The five questions I should ask in the follow-up meeting to expose gaps. Be direct. I've seen a lot of slide-ware.\n\n[Paste deck content or describe what was shown]" },
      { title: 'Devil\'s Advocate', desc: 'Red team any AI deployment decision before it ships.', prompt: "I'm about to recommend [DECISION]. Play devil's advocate. What are the strongest arguments against this? What assumptions am I making that could be wrong? What's the failure mode that would be most embarrassing six months from now? What would someone who strongly disagrees with me say, and do they have a point? Don't be polite — be right.\n\n[DECISION]: " },
      { title: 'Contract Red Team', desc: 'Identify gaps and risks in AI vendor contracts.', prompt: 'Review this AI vendor contract section for: (1) Data rights and ownership ambiguities, (2) Model training on your data clauses, (3) Uptime/SLA commitments and what\'s excluded, (4) Security and compliance representations that need verification, (5) Lock-in mechanisms that limit future vendor switching. Flag anything that would concern a government contracting officer or security officer.\n\n[Paste contract language]' },
    ],
  },
  {
    name: 'Policy & Strategy',
    prompts: [
      { title: 'Policy Memo Draft', desc: 'Draft AI policy guidance in proper government format.', prompt: 'Draft a policy memo on [TOPIC] for [AUDIENCE]. Format: standard government memo with DATE, TO, FROM, SUBJECT, SUMMARY (2-3 sentences), BACKGROUND, POLICY GUIDANCE (numbered), IMPLEMENTATION TIMELINE, and POINT OF CONTACT. Tone: direct, clear, no jargon. Flag any areas where legal review is needed.\n\nTOPIC: \nAUDIENCE: ' },
      { title: 'Risk Assessment', desc: 'Structure a risk assessment for an AI deployment decision.', prompt: "Conduct a structured risk assessment for deploying [AI CAPABILITY] in [CONTEXT]. For each risk category (Security, Data, Operational, Compliance, Reputational), identify: the specific risk, likelihood (High/Medium/Low), impact (High/Medium/Low), and a mitigation approach. Add a summary risk matrix and your recommended go/no-go with conditions.\n\nAI CAPABILITY: \nCONTEXT: " },
    ],
  },
  {
    name: 'Teaching & Explanation',
    prompts: [
      { title: 'Explain to Non-Technical Leadership', desc: 'Translate AI concepts for senior leaders without technical background.', prompt: "Explain [CONCEPT] to a senior government official who understands strategy and policy but not technology. Use an analogy to something from defense or government operations. Avoid jargon. Focus on: what it means for their decisions, what risks they should be aware of, and what question they should be asking their technical staff. Keep it under 200 words.\n\nCONCEPT: " },
      { title: 'Training Module Outline', desc: 'Structure an AI literacy training module for government employees.', prompt: "Design a 60-minute AI literacy training module for [AUDIENCE]. Include: learning objectives (3-5), module outline with time allocations, key concepts to cover, common misconceptions to address, one hands-on exercise, and 3 takeaways participants should be able to apply immediately. Make it practical, not theoretical.\n\nAUDIENCE: " },
    ],
  },
];
---

<Base title="Prompts" description="A curated library of prompts for AI briefing, vendor evaluation, policy drafting, and teaching.">
  <div class="page-wrap">
    <header class="page-header">
      <p class="eyebrow">Prompts</p>
      <h1 class="page-title">Prompt library</h1>
      <p class="page-sub">Prompts that actually work for government AI program management — briefing leadership, evaluating vendors, drafting policy, and explaining AI to non-technical audiences.</p>
    </header>

    {categories.map(cat => (
      <div class="category">
        <h2 class="category-title">{cat.name}</h2>
        <div class="prompt-grid">
          {cat.prompts.map(p => (
            <div class="prompt-card">
              <div class="prompt-header">
                <h3 class="prompt-title">{p.title}</h3>
                <p class="prompt-desc">{p.desc}</p>
              </div>
              <div class="prompt-body">
                <pre class="prompt-text">{p.prompt}</pre>
              </div>
              <button class="copy-btn" data-prompt={p.prompt}>Copy Prompt</button>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</Base>

<script>
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const text = btn.getAttribute('data-prompt') || '';
      navigator.clipboard.writeText(text).then(() => {
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = 'Copy Prompt'; }, 2000);
      });
    });
  });
</script>

<style>
  .page-wrap { max-width: 900px; margin: 0 auto; padding: 120px 32px 80px; }
  .page-header { margin-bottom: 64px; }
  .eyebrow { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent); margin-bottom: 12px; }
  .page-title { font-size: 40px; font-weight: 600; letter-spacing: -0.03em; color: var(--white); margin-bottom: 16px; }
  .page-sub { font-size: 16px; color: var(--text); line-height: 1.7; }

  .category { margin-bottom: 56px; }
  .category-title { font-size: 14px; font-weight: 600; color: var(--secondary); margin-bottom: 16px; padding-bottom: 12px; border-bottom: 1px solid var(--border); }
  .prompt-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; }

  .prompt-card {
    background: var(--surface); border: 1px solid var(--border); border-radius: 12px;
    padding: 24px; display: flex; flex-direction: column; gap: 16px;
  }
  .prompt-title { font-size: 14px; font-weight: 500; color: var(--primary); margin-bottom: 6px; }
  .prompt-desc { font-size: 12px; color: var(--mid); line-height: 1.5; }
  .prompt-body {
    background: var(--bg); border: 1px solid var(--border); border-radius: 8px;
    padding: 14px; flex: 1;
  }
  .prompt-text {
    font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--text);
    line-height: 1.6; white-space: pre-wrap; word-break: break-word;
  }
  .copy-btn {
    font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.05em;
    text-transform: uppercase; padding: 9px; border-radius: 7px; border: none;
    background: var(--accent-glow); color: var(--accent); cursor: pointer;
    border: 1px solid var(--accent-border); transition: all 0.15s;
  }
  .copy-btn:hover { background: var(--accent); color: #fff; }

  @media (max-width: 700px) { .prompt-grid { grid-template-columns: 1fr; } }
</style>
